# Template variabili d'ambiente per docker-compose (copia in .env, che e' gitignored).
# I token reali vivono solo sul box in /home/mak/esp-naso/.env

# Token scoped write sul bucket "aria" — usato da telegraf (outputs.influxdb_v2)
INFLUX_TOKEN=your-aria-write-token-here

# Token all-access InfluxDB — usato SOLO da DOCKER_INFLUXDB_INIT_ADMIN_TOKEN al primo setup del volume
INFLUX_ADMIN_TOKEN=your-influx-admin-token-here
